{
  "apps": [
    {
      "name": "Github CLI",
      "current": "1.0.9",
      "source": {
        "type": "github",
        "github": {
          "repo": "cli/cli"
        }
      },
      "transform": [
        {
          "type": "regex",
          "params": ["v\\d+\\.\\d+\\.\\d+"]
        }
      ]
    },
    {
      "name": "Amap",
      "current": "0.0.1",
      "source": {
        "type": "html",
        "html": {
          "url": "https://www.sikorskiy.net/info/prj/amap/index.html",
          "selector": "#download + ul > li:nth-child(2) ul li a"
        }
      },
      "transform": [
        {
          "type": "split",
          "params": ["v", "1"]
        }
      ]
    }
  ]
}